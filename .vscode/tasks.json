{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++ Project",
            "type": "shell",
            "command": "/usr/bin/g++",
            "args": [
                "-g",
                "src/multithread/main.cpp",
                "src/multithread/dataset.cpp",
                "-Iinclude/multithread",
                "-std=c++20",
                "-pthread",
                "-fopenmp",
                "-o",
                "build/main"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build C++ Project (Windows)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "src/multithread/main.cpp",
                "src/multithread/dataset.cpp",
                "-Iinclude/multithread",
                "-std=c++20",
                "-pthread",
                "-fopenmp",
                "-o",
                "build/main.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build C++ Project (Profiling)",
            "type": "shell",
            "command": "/usr/bin/g++",
            "args": [
                "-O3",
                "-g",
                "-fno-omit-frame-pointer",
                "src/multithread/main.cpp",
                "src/multithread/dataset.cpp",
                "-Iinclude/multithread",
                "-std=c++20",
                "-pthread",
                "-fopenmp",
                "-o",
                "build/main_profiling"
            ],
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "type": "shell",
            "label": "C/C++: g++ build active file",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        }
    ]
}